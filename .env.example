# Application
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=replace-with-a-long-random-value
CORS_ORIGINS=http://localhost:3000

# PostgreSQL / pgvector
POSTGRES_DB=engineering_memory
POSTGRES_USER=engineering_memory
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://engineering_memory:change-me@postgres:5432/engineering_memory

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Future integration configuration (intentionally unused in this scaffold)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
OPENAI_API_KEY=
